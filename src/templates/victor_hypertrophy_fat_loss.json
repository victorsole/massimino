{
    "program_name": "Victor's Hypertrophy & Fat Loss Program",
    "program_id": "victor-hypertrophy-fat-loss",
    "description": "12-week evidence-based hypertrophy and fat loss program designed for experienced lifters. Built on Van Every et al. (2026) research, featuring 3 mesocycles with progressive overload across 4 weekly sessions. Includes step machine warmup protocol, compound-first training, and structured deload weeks.",
    "goal": "Hypertrophy & Fat Loss",
    "methodology": "Evidence-Based Periodization",
    "total_workouts": 48,
    "duration": "12 weeks",
    "target_audience": "Experienced lifters (10+ years) seeking hypertrophy with simultaneous fat loss through structured periodization",
    "phases_covered": [
      {
        "phase": 1,
        "phase_name": "Foundation",
        "workouts": "Weeks 1-4",
        "focus": "Re-establish progressive overload patterns, moderate volume at 8-12 reps, 2-3 RIR. Deload in Week 4."
      },
      {
        "phase": 2,
        "phase_name": "Accumulation",
        "workouts": "Weeks 5-8",
        "focus": "Increase volume and introduce intensity techniques, 6-12 reps, 1-2 RIR. Peak volume in Week 7, deload in Week 8."
      },
      {
        "phase": 3,
        "phase_name": "Intensification",
        "workouts": "Weeks 9-12",
        "focus": "Peak intensity with slight volume reduction, 5-10 reps, 0-1 RIR. Push strength PRs and taper into reassessment."
      }
    ],
    "metadata": {
      "author": "Victor Sole Ferioli",
      "level": "Advanced",
      "settings": ["Gym"],
      "frequency": "4 sessions/week (flexible to 3 or 5)",
      "session_length": "60 minutes maximum",
      "equipment": ["Barbell", "Dumbbells", "Cable Machine", "Step Machine", "Leg Press", "Leg Extension", "Leg Curl", "Pull-up Bar"],
      "supplements": "Creatine (daily), ESN Whey Isolate (morning, post-workout, optional pre-bed + magnesium)"
    },
    "program_philosophy": {
      "principles": [
        "Mechanical tension is the primary driver of hypertrophy — every session prioritizes compound movements with progressive overload",
        "No time wasted chasing hormonal spikes or 'the pump' — every minute of your 60 is purposeful",
        "Progressive overload across 12 weeks with structured volume and intensity increases",
        "Fat loss comes from energy deficit created by training + daily activity + reasonable nutrition",
        "Step machine warmup is non-negotiable — doubles as steady-state cardio for caloric expenditure and cardiovascular health"
      ],
      "evidence_base": "Van Every DW, Lees MJ, Wilson B, Nippard J, Phillips SM. Load-induced human skeletal muscle hypertrophy: Mechanisms, myths, and misconceptions. Journal of Sport and Health Science, 2026;15:101104."
    },
    "progression_protocol": {
      "description": "Every week, try to do at least one of the following on each exercise:",
      "methods": [
        "Add weight (even 1-2 kg counts)",
        "Add a rep within the prescribed range",
        "Add a set (within the phase prescription)"
      ],
      "rule": "If you hit the top of the rep range for all prescribed sets, increase the load next session by the smallest increment available."
    },
    "nutrition_guidelines": {
      "protein_target": "1.6-2.2 g/kg bodyweight daily",
      "creatine": "3-5 g daily, timing doesn't matter — consistency does",
      "principles": [
        "Eat protein first at every meal",
        "Don't restrict food groups — be mindful of portions on calorie-dense foods",
        "Pair carbs with solid protein source and vegetables",
        "Keep alcohol moderate (blunts MPS and adds empty calories)",
        "Stay hydrated, especially with creatine supplementation",
        "Magnesium before bed supports sleep quality and recovery"
      ]
    },
